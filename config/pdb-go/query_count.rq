# Endpoint: https://rdfportal.org/pdb/sparql
PREFIX pdbo: <http://rdf.wwpdb.org/schema/pdbx-with-vrptx-v50.owl#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

SELECT COUNT(DISTINCT *)
FROM <http://rdfportal.org/dataset/pdbj>
WHERE {
  ?pdb pdbo:has_pdbx_sifts_xref_db_segmentsCategory/pdbo:has_pdbx_sifts_xref_db_segments [
    pdbo:pdbx_sifts_xref_db_segments.xref_db "GO" ;
    pdbo:pdbx_sifts_xref_db_segments.xref_db_acc ?target
  ] .
}
