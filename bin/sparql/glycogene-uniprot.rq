PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX geneid: <http://purl.uniprot.org/geneid/>

SELECT DISTINCT (STRAFTER(STR(?gene), "http://purl.uniprot.org/geneid/") AS ?gene_id) (STRAFTER(STR(?uniprot), "http://purl.uniprot.org/uniprot/") AS ?uniprot_id) {
  VALUES ?gene {
    {{gene}}
  }
  ?uniprot rdfs:seeAlso ?gene .
}